{
  "expo": {
    "name": "LED Billboard Marketplace",
    "slug": "led-billboard-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ledbillboard.marketplace",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LED Billboard Marketplace uses your location while the app is open to show driver position to dispatch operators and record proof-of-display arrival at billboard sites.",
        "NSCameraUsageDescription": "LED Billboard Marketplace uses the camera to photograph billboard displays as proof-of-service evidence for booking verifications."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ledbillboard.marketplace",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "http://localhost:8081/api"
    }
  }
}
