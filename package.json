{
  "name": "led-billboard-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "B2B marketplace for mobile LED billboard truck operators in Texas",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --stream run dev",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test",
    "test:e2e:web": "playwright test",
    "test:e2e:web:docker": "PLAYWRIGHT_BASE_URL=http://localhost:4000 API_URL=http://localhost:4001/api INTERNAL_SERVICE_KEY=docker-internal-service-key TEST_PHONE=+15551234567 playwright test --config=playwright.docker.config.ts",
    "test:e2e:web:docker:realtime": "PLAYWRIGHT_BASE_URL=http://localhost:4000 API_URL=http://localhost:4001/api INTERNAL_SERVICE_KEY=docker-internal-service-key TEST_PHONE=+15551234567 playwright test tests/e2e-web/tests/realtime-refresh.spec.ts --config=playwright.docker.config.ts --project=chromium --workers=1",
    "test:e2e:mobile": "cd tests/e2e-mobile && pnpm test",
    "test:e2e:mobile:ios": "cd tests/e2e-mobile && pnpm test:ios",
    "test:e2e:mobile:android": "cd tests/e2e-mobile && pnpm test:android",
    "test:e2e:all": "pnpm test:e2e:web && pnpm test:e2e:mobile",
    "clean": "pnpm --recursive run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.58.2",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.1"
}
