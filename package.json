{
  "name": "led-billboard-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "B2B marketplace for mobile LED billboard truck operators in Texas",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --stream run dev",
    "dev:api": "node scripts/check-db-url-sync.mjs && pnpm --parallel --stream --filter @led-billboard/db --filter @led-billboard/api run dev",
    "check:db-url-sync": "node scripts/check-db-url-sync.mjs",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive --filter=!@led-billboard/e2e-mobile run test",
    "test:all": "pnpm --recursive run test",
    "test:e2e:web": "playwright test",
    "test:e2e:web:docker": "PLAYWRIGHT_BASE_URL=${PLAYWRIGHT_BASE_URL:-http://localhost:8001} API_URL=${API_URL:-http://localhost:8002/api} INTERNAL_SERVICE_KEY=docker-internal-service-key TEST_PHONE=+15551234567 playwright test --config=playwright.docker.config.ts",
    "test:e2e:web:docker:stack": "bash ./scripts/test-e2e-web-docker.sh",
    "test:e2e:web:docker:realtime": "PLAYWRIGHT_BASE_URL=${PLAYWRIGHT_BASE_URL:-http://localhost:8001} API_URL=${API_URL:-http://localhost:8002/api} INTERNAL_SERVICE_KEY=docker-internal-service-key TEST_PHONE=+15551234567 playwright test tests/e2e-web/tests/realtime-refresh.spec.ts --config=playwright.docker.config.ts --project=chromium --workers=1",
    "test:e2e:mobile": "cd tests/e2e-mobile && pnpm test",
    "test:e2e:mobile:ios": "cd tests/e2e-mobile && pnpm test:ios",
    "test:e2e:mobile:android": "cd tests/e2e-mobile && pnpm test:android",
    "test:e2e:mobile:android:audit": "bash ./tests/e2e-mobile/scripts/full-android-audit.sh",
    "ios:metro": "bash ./scripts/ios/ensure-metro-8082.sh",
    "ios:dev": "bash ./scripts/ios/ensure-metro-8082.sh && bash ./scripts/ios/launch-dev-client.sh",
    "ios:test:fast": "bash ./scripts/ios/ensure-metro-8082.sh && bash ./scripts/ios-test-lane.sh fast",
    "ios:test:fast:regression": "bash ./scripts/ios/run-fastregression.sh",
    "ios:test:local-auth:ci": "bash ./scripts/ios/run-xctest-config.sh LocalAuthE2E",
    "ios:test:a11y:ci": "bash ./scripts/ios/run-xctest-config.sh Accessibility",
    "ios:test:e2e-local-auth": "bash ./scripts/ios-test-lane.sh local-auth",
    "ios:test:a11y": "bash ./scripts/ios-test-lane.sh a11y",
    "ios:test:state-recovery": "bash ./scripts/ios-test-lane.sh state-recovery",
    "smoke:staging:driver-checkpoint": "node packages/api/scripts/staging_driver_checkpoint.mjs",
    "test:e2e:all": "pnpm test:e2e:web && pnpm test:e2e:mobile",
    "clean": "pnpm --recursive run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.58.2",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.1",
  "pnpm": {
    "overrides": {
      "react": "18.2.0",
      "react-dom": "18.2.0",
      "basic-ftp": ">=5.2.0",
      "fast-xml-parser": ">=5.3.8",
      "minimatch": ">=10.2.3",
      "glob": ">=10.5.0",
      "babel-plugin-module-resolver>glob": "^9",
      "@react-native-community/cli-platform-ios>glob": "^7",
      "@react-native-community/cli-platform-android>glob": "^7",
      "serialize-javascript": ">=7.0.3",
      "tar": ">=7.5.4",
      "lodash": ">=4.17.23",
      "semver": ">=7.5.2",
      "axios": ">=1.13.5"
    }
  }
}
