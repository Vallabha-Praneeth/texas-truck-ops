# Server Configuration
NODE_ENV=development
PORT=3001

# Database (Neon Postgres)
DATABASE_URL='postgresql://neondb_owner:npg_wAzUqjm8pi7a@ep-summer-boat-aihw44kr-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# Redis (Upstash) - Note: Use `rediss://` for TLS connections on Upstash
REDIS_URL="rediss://YOUR_UPSTASH_REDIS_REST_URL"

# S3-Compatible Storage (for proof uploads)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=led-billboard-proofs
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# JWT Secret (for auth tokens)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
INTERNAL_SERVICE_KEY=replace-with-long-random-internal-key

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
ALLOW_OTP_FALLBACK=false

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
