{
    "name": "@led-billboard/db",
    "version": "0.1.0",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "prebuild": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "clean": "rm -rf dist",
        "db:generate": "drizzle-kit generate:pg",
        "db:migrate": "drizzle-kit push:pg",
        "db:studio": "drizzle-kit studio",
        "migrate": "tsx src/migrate.ts",
        "db:seed": "tsx src/seed.ts"
    },
    "dependencies": {
        "drizzle-orm": "^0.29.3",
        "pg": "^8.18.0",
        "postgres": "^3.4.3"
    },
    "devDependencies": {
        "@types/node": "^20.11.5",
        "dotenv": "^17.2.3",
        "drizzle-kit": "^0.20.10",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3"
    }
}